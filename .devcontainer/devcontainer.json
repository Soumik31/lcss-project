{
  "name": "LCSS PHP Project",
  "image": "mcr.microsoft.com/devcontainers/base:alpine",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Website",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": ["bmewburn.vscode-intelephense-client"]
    }
  }
}
