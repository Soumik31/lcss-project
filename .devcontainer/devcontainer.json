{
  "name": "LCSS PHP Project",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Website",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "felixfbecker.php-debug"
      ]
    }
  },
  "remoteUser": "vscode"
}
