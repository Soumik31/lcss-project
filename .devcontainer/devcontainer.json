{
  "name": "LCSS PHP Project",
  "image": "webdevops/php-apache:8.1",
  "forwardPorts": [80, 3306],
  "portsAttributes": {
    "80": {
      "label": "Website",
      "onAutoForward": "openBrowser"
    }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": ["bmewburn.vscode-intelephense-client"]
    }
  }
}
